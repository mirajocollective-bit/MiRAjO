{
  "buildCommand": null,
  "outputDirectory": ".",
  "crons": [
    { "path": "/api/send-emails",    "schedule": "0 9 * * *" },
    { "path": "/api/inactive-nudge", "schedule": "0 14 * * *" },
    { "path": "/api/mm-notify",      "schedule": "0 8 * * *" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Powered-By", "value": "" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ],
  "redirects": [
    { "source": "/blog/the-leadership-time-trap-are-you-stuck-in-a-loop",             "destination": "https://www.directory.mirajoco.org/blog/the-leadership-time-trap-are-you-stuck-in-a-loop",             "permanent": true },
    { "source": "/blog/3-levels-of-life-can-you-pass-the-test",                       "destination": "https://www.directory.mirajoco.org/blog/3-levels-of-life-can-you-pass-the-test",                       "permanent": true },
    { "source": "/blog/what-if-you-didn-t-have-to-suffer",                            "destination": "https://www.directory.mirajoco.org/blog/what-if-you-didn-t-have-to-suffer",                            "permanent": true },
    { "source": "/blog/practice-being-in-the-present-moment",                         "destination": "https://www.directory.mirajoco.org/blog/practice-being-in-the-present-moment",                         "permanent": true },
    { "source": "/blog/outsourcing-awareness-rebuilding-trust-in-your-own-intuition", "destination": "https://www.directory.mirajoco.org/blog/outsourcing-awareness-rebuilding-trust-in-your-own-intuition", "permanent": true }
  ],
  "rewrites": [
    { "source": "/blog",              "destination": "/blog.html" },
    { "source": "/25daysand25nights", "destination": "/25daysand25nights.html" },
    { "source": "/events",          "destination": "/events.html" },
    { "source": "/philosophy",      "destination": "/philosophy.html" },
    { "source": "/programs",        "destination": "/programs.html" },
    { "source": "/search_results",  "destination": "https://directory.mirajoco.org/search_results" },
    { "source": "/login",           "destination": "https://directory.mirajoco.org/login" },
    { "source": "/join",            "destination": "https://directory.mirajoco.org/join" },
    { "source": "/checkout/:path*", "destination": "https://directory.mirajoco.org/checkout/:path*" },
    { "source": "/newsletter",      "destination": "https://directory.mirajoco.org/newsletter" },
    { "source": "/categories",      "destination": "https://directory.mirajoco.org/categories" },
    { "source": "/locations",       "destination": "https://directory.mirajoco.org/locations" },
    { "source": "/faq",             "destination": "https://directory.mirajoco.org/faq" },
    { "source": "/about/contact",   "destination": "https://directory.mirajoco.org/about/contact" },
    { "source": "/about/terms",     "destination": "https://directory.mirajoco.org/about/terms" },
    { "source": "/about/privacy",   "destination": "https://directory.mirajoco.org/about/privacy" },
    { "source": "/coaching",          "destination": "/coaching.html" },
    { "source": "/programs/login",    "destination": "/programs/login.html" },
    { "source": "/programs/confirm",  "destination": "/programs/confirm.html" },
    { "source": "/programs/dashboard",    "destination": "/programs/dashboard.html" },
    { "source": "/leadnowprogram",              "destination": "/leadnowprogram.html" },
    { "source": "/womenimpactnetwork",         "destination": "/womenimpactnetwork.html" },
    { "source": "/programs/course/:slug",               "destination": "/programs/course.html" },
    { "source": "/couplesinentrepreneurship",           "destination": "/couplesinentrepreneurship.html" },
    { "source": "/programs/couples-confirm",            "destination": "/programs/couples-confirm.html" },
    { "source": "/programs/couples-join",               "destination": "/programs/couples-join.html" },
    { "source": "/programs/couples-dashboard",          "destination": "/programs/couples-dashboard.html" },
    { "source": "/programs/couples-diagnostic",         "destination": "/programs/couples-diagnostic.html" },
    { "source": "/programs/couples-report",             "destination": "/programs/couples-report.html" },
    { "source": "/programs/couples-course/:slug",       "destination": "/programs/couples-course.html" },
    { "source": "/programs/certificate",         "destination": "/programs/certificate.html" },
    { "source": "/resources/pocket-guide",       "destination": "/resources/pocket-guide.html" },
    { "source": "/resources/journal",            "destination": "/resources/journal.html" },
    { "source": "/resources/nutrition-guide",    "destination": "/resources/nutrition-guide.html" },
    { "source": "/resources/daily-schedule",     "destination": "/resources/daily-schedule.html" },
    { "source": "/test-checkout",                "destination": "/test-checkout.html" },
    { "source": "/couples-scorecard",            "destination": "/couples-scorecard.html" },
    { "source": "/alignment-audit",              "destination": "/alignment-audit.html" },
    { "source": "/media-kit",                    "destination": "/media-kit.html" },
    { "source": "/tools/money-moves",           "destination": "/tools/money-moves/login.html" },
    { "source": "/tools/money-moves/login",     "destination": "/tools/money-moves/login.html" },
    { "source": "/tools/money-moves/confirm",   "destination": "/tools/money-moves/confirm.html" },
    { "source": "/tools/money-moves/dashboard", "destination": "/tools/money-moves/dashboard.html" },
    { "source": "/tools/money-moves/settings",  "destination": "/tools/money-moves/settings.html" },
    { "source": "/tools/money-moves/reports",   "destination": "/tools/money-moves/reports.html" }
  ]
}
