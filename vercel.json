{
  "buildCommand": null,
  "outputDirectory": ".",
  "crons": [
    { "path": "/api/send-emails",    "schedule": "0 9 * * *" },
    { "path": "/api/inactive-nudge", "schedule": "0 14 * * *" },
    { "path": "/api/mm-notify",      "schedule": "0 8 * * *" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Powered-By", "value": "" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://unpkg.com https://cdn.jsdelivr.net https://challenges.cloudflare.com https://www.googletagmanager.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://*.supabase.co https://www.google-analytics.com https://analytics.google.com https://region1.google-analytics.com https://www.googletagmanager.com https://cdn.jsdelivr.net; frame-src https://www.youtube.com https://www.youtube-nocookie.com https://challenges.cloudflare.com https://lookerstudio.google.com; worker-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self';" }
      ]
    }
  ],
  "redirects": [
    { "source": "/blog/the-leadership-time-trap-are-you-stuck-in-a-loop",             "destination": "/blog", "permanent": false },
    { "source": "/blog/3-levels-of-life-can-you-pass-the-test",                       "destination": "/blog", "permanent": false },
    { "source": "/blog/what-if-you-didn-t-have-to-suffer",                            "destination": "/blog", "permanent": false },
    { "source": "/blog/practice-being-in-the-present-moment",                         "destination": "/blog", "permanent": false },
    { "source": "/blog/outsourcing-awareness-rebuilding-trust-in-your-own-intuition", "destination": "/blog", "permanent": false }
  ],
  "rewrites": [
    { "source": "/blog",                    "destination": "/blog.html" },
    { "source": "/blog/i-can-move",                  "destination": "/blog/i-can-move.html" },
    { "source": "/blog/who-stole-your-superpower",        "destination": "/blog/who-stole-your-superpower.html" },
    { "source": "/blog/internal-vs-external-dialogue",          "destination": "/blog/internal-vs-external-dialogue.html" },
    { "source": "/blog/practice-being-in-the-present-moment",  "destination": "/blog/practice-being-in-the-present-moment.html" },
    { "source": "/25daysand25nights", "destination": "/25daysand25nights.html" },
    { "source": "/events",          "destination": "/events.html" },
    { "source": "/philosophy",      "destination": "/philosophy.html" },
    { "source": "/programs",        "destination": "/programs.html" },
    { "source": "/login",           "destination": "/programs/login" },
    { "source": "/about/contact",   "destination": "/coaching" },
    { "source": "/about/terms",     "destination": "/about/terms.html" },
    { "source": "/about/privacy",   "destination": "/about/privacy.html" },
    { "source": "/coaching",          "destination": "/coaching.html" },
    { "source": "/programs/login",    "destination": "/programs/login.html" },
    { "source": "/programs/confirm",  "destination": "/programs/confirm.html" },
    { "source": "/programs/dashboard",    "destination": "/programs/dashboard.html" },
    { "source": "/leadnowprogram",              "destination": "/tbc-win/leadnowprogram.html" },
    { "source": "/womenimpactnetwork",         "destination": "/tbc-win/womenimpactnetwork.html" },
    { "source": "/programs/course/:slug",               "destination": "/programs/course.html" },
    { "source": "/couplesinentrepreneurship",           "destination": "/couplesinentrepreneurship.html" },
    { "source": "/programs/couples-confirm",            "destination": "/programs/couples-confirm.html" },
    { "source": "/programs/couples-join",               "destination": "/programs/couples-join.html" },
    { "source": "/programs/couples-dashboard",          "destination": "/programs/couples-dashboard.html" },
    { "source": "/programs/couples-diagnostic",         "destination": "/programs/couples-diagnostic.html" },
    { "source": "/programs/couples-profile",            "destination": "/programs/couples-profile.html" },
    { "source": "/programs/couples-report",             "destination": "/programs/couples-report.html" },
    { "source": "/programs/couples-course/:slug",       "destination": "/programs/couples-course.html" },
    { "source": "/programs/certificate",         "destination": "/programs/certificate.html" },
    { "source": "/resources/pocket-guide",       "destination": "/resources/pocket-guide.html" },
    { "source": "/resources/journal",            "destination": "/resources/journal.html" },
    { "source": "/resources/nutrition-guide",    "destination": "/resources/nutrition-guide.html" },
